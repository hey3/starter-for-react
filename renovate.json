{
  "extends": [
    ":dependencyDashboard",
    ":semanticPrefixFixDepsChoreOthers",
    ":ignoreModulesAndTests",
    "replacements:all",
    "workarounds:all",
    "customManagers:githubActionsVersions"
  ],
  "timezone": "Asia/Tokyo",
  "schedule": ["every weekend"],
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true,
    "schedule": ["before 3am on the first day of the month"]
  },
  "labels": ["renovate"],
  "commitMessagePrefix": "ci: ",
  "vulnerabilityAlerts": {
    "labels": ["security"]
  },
  "enabledManagers": ["npm", "github-actions"],
  "separateMinorPatch": true,
  "patch": {
    "automerge": true
  },
  "minimumReleaseAge": "7 days",
  "packageRules": [
    {
      "groupName": "Typescript",
      "matchPackageNames": ["typescript"]
    },
    {
      "groupName": "React families",
      "matchPackageNames": ["react", "react-dom", "@types/react", "@types/react-dom"]
    },
    {
      "groupName": "Routing families",
      "matchPackageNames": ["react-router"]
    },
    {
      "groupName": "ESLint families",
      "matchPackageNames": ["eslint", "typescript-eslint", "globals", "/^eslint/", "/^@eslint/"]
    },
    {
      "groupName": "StyleLint families",
      "matchPackageNames": ["/^stylelint/"]
    },
    {
      "groupName": "Formatter families",
      "matchPackageNames": ["prettier"]
    },
    {
      "groupName": "Test families",
      "matchPackageNames": ["vitest", "jsdom"]
    },
    {
      "groupName": "Test Utility families",
      "matchPackageNames": ["/^@testing-library/"]
    },
    {
      "groupName": "Storybook families",
      "matchPackageNames": ["storybook", "/^@storybook/"]
    },
    {
      "groupName": "Builder families",
      "matchPackageNames": ["vite", "@vitejs/plugin-react-swc"]
    }
  ]
}
